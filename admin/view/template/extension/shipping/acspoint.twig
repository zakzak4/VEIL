{{ header }}{{ column_left }}
<div id="content">
    <div class="page-header">
        <div class="container-fluid">
            <div class="pull-right">
                <button type="submit" form="form-shipping" data-toggle="tooltip" title="{{ button_save }}"
                        class="btn btn-primary"><i class="fa fa-save"></i></button>
                <a href="{{ cancel }}" data-toggle="tooltip" title="{{ button_cancel }}" class="btn btn-default"><i
                        class="fa fa-reply"></i></a></div>
            <h1>{{ heading_title }}</h1>
            <ul class="breadcrumb">
                {% for breadcrumb in breadcrumbs %}
                    <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
                {% endfor %}
            </ul>
        </div>
    </div>
    <div class="container-fluid">
        {% if error_warning %}
            <div class="alert alert-danger alert-dismissible"><i
                    class="fa fa-exclamation-circle"></i> {{ error_warning }}
                <button type="button" class="close" data-dismiss="alert">&times;</button>
            </div>
        {% endif %}
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-shipping"
              class="form-horizontal">
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> Configuration Settings</h3>
                </div>
                <div class="panel-body">

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-status">{{ entry_status }}</label>
                        <div class="col-sm-10">
                            <select name="shipping_acspoint_status" id="input-status" class="form-control">
                                {% if shipping_acspoint_status %}
                                    <option value="1" selected="selected">{{ text_enabled }}</option>
                                    <option value="0">{{ text_disabled }}</option>
                                {% else %}
                                    <option value="1">{{ text_enabled }}</option>
                                    <option value="0" selected="selected">{{ text_disabled }}</option>
                                {% endif %}
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-title">{{ entry_title }}</label>
                        <div class="col-sm-7">
                            <input type="text" name="shipping_acspoint_title" value="{{ shipping_acspoint_title }}"
                                   id="input-title" class="form-control"/>
                        </div>
                        <label class="col-sm-2 control-label" for="input-sort-order">{{ entry_sort_order }}</label>
                        <div class="col-sm-1">
                            <input type="number" name="shipping_acspoint_sort_order"
                                   value="{{ shipping_acspoint_sort_order }}" id="input-sort-order"
                                   class="form-control"/>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-countries_availability">Countries
                            Availability</label>
                        <div class="col-sm-4">
                            <select name="shipping_acspoint_countries_availability" id="input-countries_availability"
                                    class="form-control">
                                <option>All</option>
                                <option value="gr"
                                        {% if shipping_acspoint_countries_availability == 'gr' %}selected="selected"{% endif %}>
                                    Greece only
                                </option>
                                <option value="cy"
                                        {% if shipping_acspoint_countries_availability == 'cy' %}selected="selected"{% endif %}>
                                    Cyprus only
                                </option>
                            </select>
                        </div>
                        <label class="col-sm-2 control-label" for="input-api_key">{{ entry_api_key }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_api_key" value="{{ shipping_acspoint_api_key }}"
                                   id="input-api_key" class="form-control"/>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-weight_limit">{{ entry_weight_limit }}</label>
                        <div class="col-sm-4">
                            <input type="number" name="shipping_acspoint_weight_limit"
                                   value="{{ shipping_acspoint_weight_limit }}" id="input-weight_limit"
                                   class="form-control"/>
                        </div>

                        <label class="col-sm-2 control-label" for="input-total">{{ entry_total }}</label>
                        <div class="col-sm-4">
                            <input type="number" name="shipping_acspoint_total" value="{{ shipping_acspoint_total }}"
                                   id="input-total" class="form-control"/>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-senderCountry">Store/Sender Country</label>
                        <div class="col-sm-4">
                            <select name="shipping_acspoint_senderCountry" id="input-senderCountry"
                                    class="form-control">
                                <option value="GR"
                                        {% if shipping_acspoint_senderCountry == 'GR' %}selected="selected"{% endif %}>
                                    Greece
                                </option>
                                <option value="CY"
                                        {% if shipping_acspoint_senderCountry == 'CY' %}selected="selected"{% endif %}>
                                    Cyprus
                                </option>
                            </select>
                        </div>
                        <label class="col-sm-2 control-label" for="input-senderZipcode">Store/Sender Zipcode</label>
                        <div class="col-sm-4">
                            <input type="number" name="shipping_acspoint_senderZipcode"
                                   value="{{ shipping_acspoint_senderZipcode }}" id="input-senderZipcode"
                                   class="form-control"/>
                        </div>
                    </div>
                </div>
            </div>
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> Authentication Settings</h3>
                </div>
                <div class="panel-body">
                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-acsCompanyID">{{ entry_acsCompanyID }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsCompanyID"
                                   value="{{ shipping_acspoint_acsCompanyID }}" id="input-acsCompanyID"
                                   class="form-control"/>
                        </div>

                        <label class="col-sm-2 control-label"
                               for="input-acsCompanyPassword">{{ entry_acsCompanyPassword }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsCompanyPassword"
                                   value="{{ shipping_acspoint_acsCompanyPassword }}" id="input-acsCompanyPassword"
                                   class="form-control"/>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-acsUserID">{{ entry_acsUserID }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsUserID"
                                   value="{{ shipping_acspoint_acsUserID }}" id="input-acsUserID" class="form-control"/>
                        </div>
                        <label class="col-sm-2 control-label"
                               for="input-acsUserPassword">{{ entry_acsUserPassword }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsUserPassword"
                                   value="{{ shipping_acspoint_acsUserPassword }}" id="input-acsUserPassword"
                                   class="form-control"/>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="col-sm-2 control-label" for="input-acsApiKey">{{ entry_acsApiKey }}</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsApiKey"
                                   value="{{ shipping_acspoint_acsApiKey }}" id="input-acsApiKey" class="form-control"/>
                        </div>
                        <label class="col-sm-2 control-label" for="input-acsClientId">Billing Code</label>
                        <div class="col-sm-4">
                            <input type="text" name="shipping_acspoint_acsClientId"
                                   value="{{ shipping_acspoint_acsClientId }}" id="input-acsClientId"
                                   class="form-control"/>
                        </div>
                    </div>
                </div>
            </div>
            <div class="panel panel-default">
                <div class="panel-heading">
                    <h3 class="panel-title"><i class="fa fa-pencil"></i> Pricing Settings</h3>
                </div>
                <div class="panel-body">

                    <table class="table">
                        <thead>
                        <tr>
                            <th>Pricing settings</th>
                            <th>Base Cost (€)</th>
                            <th>Base KG Limit</th>
                            <th>Cost Per KG (€)</th>
                        </tr>
                        </thead>
                        <tbody>

                        <tr>
                            <td><strong>ΕΝΤΟΣ ΠΟΛΗΣ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[same_city][baseCost]"
                                       value="{{ shipping_acspoint_pricing.same_city.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[same_city][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.same_city.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[same_city][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.same_city.costPerKg }}"></td>
                        </tr>
                        <tr>
                            <td><strong>ΝΗΣΙΩΤΙΚΟΣ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[island][baseCost]"
                                       value="{{ shipping_acspoint_pricing.island.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[island][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.island.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[island][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.island.costPerKg }}"></td>
                        </tr>
                        <tr>
                            <td><strong>ΠΕΡΙΦΕΡΕΙΑ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[region][baseCost]"
                                       value="{{ shipping_acspoint_pricing.region.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[region][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.region.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[region][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.region.costPerKg }}"></td>
                        </tr>
                        <tr>
                            <td><strong>ΧΕΡΣΑΙΑ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[overland][baseCost]"
                                       value="{{ shipping_acspoint_pricing.overland.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[overland][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.overland.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[overland][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.overland.costPerKg }}"></td>
                        </tr>
                        <tr>
                            <td><strong>ΕΝΤΟΣ ΚΥΠΡΟΥ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[internal_cyprus][baseCost]"
                                       value="{{ shipping_acspoint_pricing.internal_cyprus.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[internal_cyprus][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.internal_cyprus.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[internal_cyprus][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.internal_cyprus.costPerKg }}"></td>
                        </tr>
                        <tr>
                            <td><strong>ΚΥΠΡΟΣ</strong></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[cyprus][baseCost]"
                                       value="{{ shipping_acspoint_pricing.cyprus.baseCost }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[cyprus][baseCostKgLimit]"
                                       value="{{ shipping_acspoint_pricing.cyprus.baseCostKgLimit }}"></td>
                            <td><input type="text" class="form-control"
                                       name="shipping_acspoint_pricing[cyprus][costPerKg]"
                                       value="{{ shipping_acspoint_pricing.cyprus.costPerKg }}"></td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </form>
    </div>
</div>
{{ footer }}
