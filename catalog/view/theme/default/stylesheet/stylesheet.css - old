body {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-weight: 300;
    color: #e0e0e0;
    font-size: 14px;
    line-height: 1.6;
    width: 100%;
    background-color: #121212 !important;
}
h1, h2, h3, h4, h5, h6, .h1, .h2, .h3 {
    color: #ffffff;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
}
/* Top Bar */
#search .form-control {
    height: 40px !important;
    padding: 10px 15px !important;
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    border: 1px solid #333 !important;
}
#content ul li a {
    color: #a89081 !important; /* Tan accent */
    text-decoration: none;
}
#content ul li a:hover {
    color: #ffffff !important;
}
/* The Search Button (Magnifying Glass) */
#search .btn-default {
    background-color: #252525 !important;
    color: #ffffff !important;
    border: 1px solid #333 !important;
    text-shadow: none !important;
    background-image: none !important;
}
#search .btn-default:hover {
    background-color: #a89081 !important;
}
/* Targets the Sorting and Show filters */
.form-control {
    background-color: #1a1a1a !important;
    border: 1px solid #333 !important;
    color: #ffffff !important;
}

/* Fixes the labels next to the dropdowns */
label.input-group-addon {
    background-color: #252525 !important;
    border: 1px solid #333 !important;
    color: #ffffff !important;
}
/* Default font size */
.fa {
	font-size: 14px;
}
/* Override the bootstrap defaults */
h1 {
	font-size: 33px;
}
h2 {
	font-size: 27px;
}
h3 {
	font-size: 21px;
}
h4 {
	font-size: 15px;
}
h5 {
	font-size: 12px;
}
h6 {
	font-size: 10.2px;
}
a {
	color: #23a1d1;
}
a:hover {
	text-decoration: none;
}
legend {
	font-size: 18px;
	padding: 7px 0px
}
label {
	font-size: 12px;
	font-weight: normal;
}
select.form-control, textarea.form-control, input[type="text"].form-control, input[type="password"].form-control, input[type="datetime"].form-control, input[type="datetime-local"].form-control, input[type="date"].form-control, input[type="month"].form-control, input[type="time"].form-control, input[type="week"].form-control, input[type="number"].form-control, input[type="email"].form-control, input[type="url"].form-control, input[type="search"].form-control, input[type="tel"].form-control, input[type="color"].form-control {
	font-size: 12px;
}
.input-group input, .input-group select, .input-group .dropdown-menu, .input-group .popover {
	font-size: 12px;
}
.input-group .input-group-addon {
	font-size: 12px;
	height: 30px;
}
/* Fix some bootstrap issues */
span.hidden-xs, span.hidden-sm, span.hidden-md, span.hidden-lg {
	display: inline;
}
.nav-tabs {
    border-bottom: 1px solid #222 !important;
	margin-bottom: 15px;
}
.tab-content {
    background-color: #111 !important;
    border: 1px solid #222;
    border-top: none;
    padding: 20px;
    color: #eee;
}
/* Style for the inactive tabs */
.nav-tabs > li > a {
    background-color: #1a1a1a !important;
    border: 1px solid #222 !important;
    color: #888 !important;
    margin-right: 2px;
}
.nav-tabs > li.active > a, 
.nav-tabs > li.active > a:hover, 
.nav-tabs > li.active > a:focus {
    background-color: #252525 !important;
    color: #ffffff !important;
    border: 1px solid #222 !important;
    border-bottom-color: transparent !important;
}
/* Hover effect for inactive tabs */
.nav-tabs > li > a:hover {
    background-color: #2a2a2a !important;
    color: #a89081 !important;
}
nav#top {
    background-color: #111 !important;
    border-bottom: 1px solid #222;
    padding: 5px 0;
}
/* Makes "My Account", "Shopping Cart", and "Checkout" readable */
nav#top .btn-link, nav#top-links li a, nav#top-links li span {
    color: #fff !important; 
    text-shadow: none !important;
}
/* Targets the links at the very top (Currency, Wish List, Checkout) */
nav#top-links li a, nav#top-links li span, nav#top .btn-link {
    color: #ffffff !important;
    text-shadow: none !important;
    font-weight: 400;
}
nav#top-links li a:hover {
    color: #a89081 !important;
}
div.required .control-label:before {
	content: '* ';
	color: #F00;
	font-weight: bold;
}
#cart-total {
    color: #ffffff !important;
    font-weight: bold;
}
/* Gradent to all drop down menus */
.dropdown-menu li > a:hover {
	text-decoration: none;
	color: #ffffff;
	background-color: #229ac8;
	background-image: linear-gradient(to bottom, #23a1d1, #1f90bb);
	background-repeat: repeat-x;
}
/* top */
#top {
    background-color: #111111 !important;
    border-bottom: 1px solid #222222;
    padding: 4px 0px 3px 0;
    margin: 0 0 20px 0;
    min-height: 40px;
}
#top .container {
	padding: 0 20px;
}
#top #form-currency .currency-select,
#top #form-language .language-select {
    text-align: left;
    color: #ffffff !important;
    background-color: #1a1a1a !important;
    border: none;
}
#top #form-currency .currency-select:hover,
#top #form-language .language-select:hover {
    text-shadow: none;
    color: #a89081 !important;
    background-color: #2a2a2a !important;
    background-image: none !important;
}
#top .btn-link, #top-links li, #top-links a {
    color: #ffffff !important;
    text-shadow: none !important;
    text-decoration: none;
}
#top .btn-link:hover, #top-links a:hover {
	color: #a89081;
}
#top-links .dropdown-menu {
    background-color: #1a1a1a !important;
    border: none !important;
    box-shadow: 0 6px 12px rgba(0,0,0,0.5);
    padding: 0;
}
#top-links .dropdown-menu a:hover {
    color: #a89081 !important;
    background-color: #2a2a2a !important;
    background-image: none !important;
}
#top-links .dropdown.open .dropdown-toggle {
    background-color: transparent !important;
    color: #ffffff !important;
}
#top .btn-link strong {
	font-size: 14px;
        line-height: 14px;
}
#top-links {
	padding-top: 6px;
}
#top-links a + a {
	margin-left: 15px;
}
#form-currency .dropdown-menu, 
#form-language .dropdown-menu,
#cart .dropdown-menu {
    border: none !important;
    background-color: #1a1a1a !important;
    box-shadow: 0 6px 12px rgba(0,0,0,0.5) !important;
}
#top .btn-link:focus, 
#top .btn-link:active, 
#top .open .btn-link {
    background-color: transparent !important;
    color: #ffffff !important;
}
/* Makes the pagination dots visible */
.swiper-pagination-bullet {
    background: #666 !important;
    opacity: 1 !important;
}
/* Makes the active dot white */
.swiper-pagination-bullet-active {
    background: #ffffff !important;
}
.slick-dots li button:before {
    color: #ffffff !important;
    opacity: 0.25;
}
.slick-dots li.slick-active button:before {
    color: #a89081 !important;
    opacity: 1;
}
/* Targets common carousel dot shapes */
.owl-dot span, .swiper-pagination-bullet, .slick-dots li button {
    background-color: #555 !important;
    border: 1px solid #333 !important;
}
.owl-dot.active span, .swiper-pagination-bullet-active, .slick-dots li.slick-active button {
    background-color: #ffffff !important;
}
/* logo */
#logo {
	margin: 0 0 10px 0;
}
/* search */
#search {
	margin-bottom: 10px;
}
#search .input-lg {
	height: 40px;
	line-height: 20px;
	padding: 0 10px;
}
#search .btn-lg {
    height: 40px !important;
    padding: 0 20px !important;
    background-color: #252525 !important;
    border: 1px solid #333 !important;
    line-height: 40px !important;
    margin: 0 !important;
    color: #ffffff !important;
}
#search .btn-lg:hover {
    background-color: #a89081 !important;
    color: #ffffff !important;
}
/* cart */
#cart {
	margin-bottom: 10px;
}
#cart > .btn {
	font-size: 12px;
	line-height: 18px;
	color: #FFF;
}
#cart.open > .btn {
	background-image: none;
	background-color: #FFFFFF;
	border: 1px solid #E6E6E6;
	color: #666;
	box-shadow: none;
	text-shadow: none;
}
#cart.open > .btn:hover {
	color: #444;
}
#cart > .btn.dropdown-toggle:focus, 
#cart > .btn.dropdown-toggle:active,
#cart.open > .btn.dropdown-toggle {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    box-shadow: none !important;
}
#cart .dropdown-menu,
#cart .dropdown-menu table,
#cart .dropdown-menu li {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    border: 1px solid #333 !important;
}
#cart .dropdown-menu {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    border: 1px solid #222 !important;
    box-shadow: 0 6px 12px rgba(0,0,0,0.5) !important;
}
@media (max-width: 478px) {
	#cart .dropdown-menu {
		width: 100%;
	}
}
#cart .dropdown-menu table tr td {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    padding: 8px;
}
#cart .dropdown-menu li > div {
	min-width: 427px;
	padding: 0 10px;
}
@media (max-width: 478px) {
	#cart .dropdown-menu li > div {
		min-width: 100%;
	}
}
#cart .dropdown-menu li:first-child,
#cart .dropdown-menu table {
    border-top: none !important;
    margin-top: 0;
}
#cart .dropdown-menu td {
    border-top: 1px solid #222 !important; 
}
#cart .dropdown-menu li p a {
    color: #a89081 !important;
    font-weight: bold;
    text-decoration: none;
}
#cart .dropdown-menu li p a:hover {
    color: #ffffff !important;
}
/* menu */
#menu {
    background-color: #1a1a1a !important;
    background-image: none !important;
    border: 1px solid #333;
    border-radius: 4px;
    min-height: 40px;
}
#menu .nav > li:hover > a {
    color: #fff;
    background-color: #2a2a2a;
}
#menu .nav > li > a:hover, #menu .nav > li.open > a {
    background-color: #2a2a2a !important;
    color: #a89081 !important;
}
#menu .nav > li > a {
    color: #fff !important;
    text-shadow: none !important;
}
#menu .dropdown-menu {
    background-color: #1a1a1a !important;
    border: 1px solid #333 !important;
    padding: 10px;
}
#menu .dropdown-inner {
	display: table;
}
#menu .dropdown-inner ul {
	display: table-cell;
}
#menu .dropdown-inner a {
	min-width: 160px;
	display: block;
	padding: 3px 20px;
	clear: both;
	line-height: 20px;
	color: #eee !important;
	font-size: 12px;
}
#menu .dropdown-inner a:hover {
    color: #fff !important;
    background-color: #2a2a2a !important;
}
#menu .dropdown-inner li a:hover {
	color: #FFFFFF;
}
#menu .see-all {
    display: block;
    margin-top: 0.5em;
    border-top: 1px solid #333 !important;
    background-color: #222 !important;
    color: #fff !important;
    padding: 3px 20px;
    border-radius: 0 0 3px 3px;
    font-size: 12px;
}
#menu .see-all:hover, #menu .see-all:focus {
	text-decoration: none;
	color: #ffffff;
	background-color: #229ac8;
	background-image: linear-gradient(to bottom, #23a1d1, #1f90bb);
	background-repeat: repeat-x;
}
#menu #category {
	float: left;
	padding-left: 15px;
	font-size: 16px;
	font-weight: 700;
	line-height: 40px;
	color: #fff;
	text-shadow: 0 1px 0 rgba(0, 0, 0, 0.2);
}
#menu .btn-navbar {
	font-size: 15px;
	font-stretch: expanded;
	color: #FFF;
	padding: 2px 18px;
	float: right;
	background-color: #229ac8;
	background-image: linear-gradient(to bottom, #23a1d1, #1f90bb);
	background-repeat: repeat-x;
	border-color: #1f90bb #1f90bb #145e7a;
}
#menu .btn-navbar:hover, #menu .btn-navbar:focus, #menu .btn-navbar:active, #menu .btn-navbar.disabled, #menu .btn-navbar[disabled] {
	color: #ffffff;
	background-color: #229ac8;
}
@media (min-width: 768px) {
	#menu .dropdown:hover .dropdown-menu {
		display: block;
	}
}
@media (max-width: 767px) {
	#menu {
		border-radius: 4px;
	}
	#menu div.dropdown-inner > ul.list-unstyled {
		display: block;
	}
	#menu div.dropdown-menu {
		margin-left: 0 !important;
		padding-bottom: 10px;
		background-color: rgba(0, 0, 0, 0.1);
	}
	#menu .dropdown-inner {
		display: block;
	}
	#menu .dropdown-inner a {
		width: 100%;
		color: #fff;
	}
	#menu .dropdown-menu a:hover,
	#menu .dropdown-menu ul li a:hover {
		background: rgba(0, 0, 0, 0.1);
	}
	#menu .see-all {
		margin-top: 0;
		border: none;
		border-radius: 0;
		color: #fff;
	}
}
/* content */
#content {
	min-height: 600px;
    background-color: transparent !important;
}
#product-category #content, #product-product #tab-description, #information-information #content {
	font-size: 13px;
}
.well {
    background-color: #1a1a1a !important;
    border: 1px solid #333 !important;
    color: #ffffff !important;
}
.well a, .well label {
    color: #a89081 !important;
}
.well .form-control {
    background-color: #252525 !important;
    color: #ffffff !important;
    border: 1px solid #444 !important;
}
/* footer */
footer {
    margin-top: 30px;
    padding-top: 30px;
    background-color: #000000 !important;
    border-top: 1px solid #222 !important;
    color: #e2e2e2;
}
footer hr {
	border-top: none;
	border-bottom: 1px solid #666;
}
footer a {
    color: #888 !important;
    text-decoration: none;
}
footer a:hover {
    color: #ffffff !important;
}
footer h5 {
	font-family: 'Open Sans', sans-serif;
	font-size: 13px;
	font-weight: bold;
	color: #fff;
}
/* alert */
.alert {
	padding: 8px 14px 8px 14px;
}
.alert > .close {
	position: relative;
	top: -2px;
	right: 0px;
	color: inherit;
}
/* breadcrumb */
.breadcrumb {
    padding: 8px 15px;
    margin-bottom: 20px;
    list-style: none;
    background-color: #1a1a1a !important;
    border: 1px solid #333 !important;
    border-radius: 4px;
}
.breadcrumb i {
	font-size: 15px;
}
.breadcrumb > li > a {
    color: #bbb !important;
    text-shadow: none !important;
}
.breadcrumb > li {
    color: #fff !important;
    text-shadow: none !important;
}
.breadcrumb > li + li:before {
	content: '';
	padding: 0;
}
.breadcrumb > li:after {
	content: '';
	display: block;
	position: absolute;
	top: -3px;
	right: -5px;
	width: 26px;
	height: 26px;
	border-right: 1px solid #DDD;
	border-bottom: 1px solid #DDD;
	-webkit-transform: rotate(-45deg);
	-moz-transform: rotate(-45deg);
	-o-transform: rotate(-45deg);
	transform: rotate(-45deg);
}
html[dir=rtl] .breadcrumb > li::after {
  top: -3px;
  left: -5px;
  width: 26px;
  height: 26px;
  border-left: 1px solid #DDD;
  border-top: 1px solid #DDD;
  right: unset;
  border-right: unset;
  border-bottom:unset;
}
.pagination {
	margin: 0;
}
/* Forces the Refresh and Remove buttons to match exactly */
.input-group-btn .btn, 
.btn-danger, 
.cart-info .btn-primary {
    padding: 8px 12px !important;
    height: 34px !important;
    font-size: 12px !important;
    line-height: 1.4 !important; 
}
/* Fixes the red button's specific border and alignment */
.btn-danger {
    border: none !important;
    vertical-align: top !important;
}
/* Darkens the Continue Shopping button */
.buttons .pull-left .btn-default {
    background-color: #252525 !important;
    background-image: none !important;
    color: #ffffff !important;
    border: 1px solid #333 !important;
    text-shadow: none !important;
}
/* Hover state for Continue Shopping */
.buttons .pull-left .btn-default:hover {
    background-color: #a89081 !important;
    border-color: #a89081 !important;
}
/* Ensures the Checkout button text is white */
.buttons .pull-right .btn-primary {
    color: #ffffff !important;
    text-shadow: none !important;
}
/* Update your block starting at line 601 */
.table-bordered, 
.table-bordered > thead > tr > th, 
.table-bordered > thead > tr > td,
.table > thead > tr > td,
.table > thead > tr > th {
    border: 1px solid #222 !important;
    border-top: 1px solid #222 !important;
    background-color: #111 !important;
    color: #ffffff !important;
}
/* Fixes the lines between the product rows */
.table-bordered > tbody > tr > td {
    border: 1px solid #222 !important;
}
/* Ensures the total price box text is white */
.table-bordered > tfoot > tr > td:first-child {
    color: #ffffff;
    font-weight: bold;
}
/* Darkens the Accordion boxes in the cart */
#accordion .panel-default {
    background-color: #1a1a1a !important;
    border: 1px solid #222 !important;
}
/* Fixes the header/title area of those boxes */
#accordion .panel-heading {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
    border-bottom: 1px solid #222 !important;
}
/* Ensures the text inside the expanded box is white */
#accordion .panel-body {
    background-color: #111 !important;
    color: #ffffff !important;
}
/* Darkens the white box on the Contact Us page */
.panel.panel-default {
    background-color: #1a1a1a !important;
    border: 1px solid #222 !important;
}
/* Fixes the text visibility inside the location box */
.panel-default > .panel-body {
    background-color: #1a1a1a !important;
    color: #ffffff !important;
	border-top: 1px solid #222 !important;
}
/* Fixes the labels for the Contact Form fields */
legend {
    color: #ffffff !important;
    border-bottom: 1px solid #333;
}
label.control-label {
    color: #ffffff !important;
}
/* Darkens the main pop-up container */
.modal-content {
    background-color: #1a1a1a !important;
    border: 1px solid #333 !important;
    color: #ffffff !important;
}
/* Forces all table borders to dark charcoal across the site */
.table-bordered, 
.table-bordered > tbody > tr > td, 
.table-bordered > thead > tr > th, 
.table-bordered > tfoot > tr > td,
.table > tbody > tr > td,
.table > tfoot > tr > td,
.table > thead > tr > td {
    border: 1px solid #222 !important;
}
/* Specifically removes the white line from the top of the table */
.table {
    border-top: 1px solid #222 !important;
}
/* Forces pop-up text and labels to white */
.modal-body label, 
.modal-body p,
.modal-body b {
    color: #ffffff !important;
}
/* Optional: Subtle background for the shipping rows */
.modal-body .radio {
    padding: 10px;
    background: #252525;
    border-radius: 4px;
    margin-bottom: 5px;
}
/* Fixes the header area of the pop-up */
.modal-header {
    border-bottom: 1px solid #222 !important;
    background-color: #111 !important;
}
/* Fixes the footer area where 'Cancel' sits */
.modal-footer {
    border-top: 1px solid #222 !important;
    background-color: #111 !important;
}
/* Ensures the Close (X) button is white */
.close {
    color: #fff !important;
    text-shadow: none !important;
    opacity: 0.8;
}
/* buttons */
.buttons {
	margin: 1em 0;
}
/* Forces the invisible text on the Register button to white */
.well .btn-primary, 
#content .btn-primary,
.buttons .btn-primary {
    color: #ffffff !important;
    text-shadow: none !important;
    text-transform: uppercase;
    font-weight: bold;
    opacity: 1 !important;
}
/* Absolute override for the Register/Continue button text */
.btn-primary, 
a.btn-primary, 
.well .btn-primary {
    color: #ffffff !important;
    text-shadow: none !important;
    text-decoration: none !important;
}
/* Ensures the text stays white when you hover over it */
.well .btn-primary:hover, 
#content .btn-primary:hover,
.buttons .btn-primary:hover {
    color: #ffffff !important;
    background-color: #8c7668 !important;
}
.btn {
	padding: 7.5px 12px;
	font-size: 12px;
	border: 1px solid #cccccc;
	border-radius: 4px;
	box-shadow: inset 0 1px 0 rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.05);
}
.btn-xs {
	font-size: 9px;
}
.btn-sm {
	font-size: 10.2px;
}
.btn-lg {
	padding: 10px 16px;
	font-size: 15px;
}
.btn-group > .btn, .btn-group > .dropdown-menu, .btn-group > .popover {
	font-size: 12px;
}
.btn-group > .btn-xs {
	font-size: 9px;
}
.btn-group > .btn-sm {
	font-size: 10.2px;
}
.btn-group > .btn-lg {
	font-size: 15px;
}
.btn-default {
	color: #777;
	text-shadow: 0 1px 0 rgba(255, 255, 255, 0.5);
	background-color: #e7e7e7;
	background-image: linear-gradient(to bottom, #eeeeee, #dddddd);
	background-repeat: repeat-x;
	border-color: #dddddd #dddddd #b3b3b3 #b7b7b7;
}
.btn-primary {
    background-color: #a89081; 
    color: #fff;
    border: none;
    border-radius: 2px;
    padding: 10px 20px;
    text-transform: uppercase;
    font-weight: 600;
}
.btn-primary:hover, .btn-primary:active, .btn-primary.active, .btn-primary.disabled, .btn-primary[disabled] {
	background-color: #967e6f;
	background-position: 0 -15px;
}
.btn-warning {
	color: #ffffff;
	text-shadow: 0 -1px 0 rgba(0, 0, 0, 0.25);
	background-color: #faa732;
	background-image: linear-gradient(to bottom, #fbb450, #f89406);
